# A secret value used for encryption and hashing. It must be at least 32 characters and generated with high entropy. 
# You can use `openssl rand -base64 32` to generate one.
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000 # Base URL of your app
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000 # Base URL used by browser auth client

# Database connection string. Replace with your actual database credentials.
DATABASE_URL="postgresql://USERNAME:PASSWORD@HOST:5432/DB_NAME"

# Google social login.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=